# Garden Companion — Environment Variables
# Copy this file to .env.local and fill in the values.

# Trefle API token (free at https://trefle.io/users/sign_up)
# Required for plant search. Without it, only OpenFarm is used as a fallback.
TREFLE_TOKEN=

# Google Gemini API key (free at https://aistudio.google.com/apikey)
# Required for seed packet OCR. Without it, falls back to Tesseract.js (less accurate).
GEMINI_API_KEY=
